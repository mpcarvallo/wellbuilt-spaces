# WellBuilt Home V4 — environment variables
#
# The questionnaire and the Home Snapshot work with NO API key: the results page
# falls back to a transparent, rule-based Snapshot. Set a key only to enable the
# optional AI-personalized Snapshot via /api/generate-snapshot.

# Optional: enables the Claude-powered Snapshot. Without it, the deterministic
# rule-based Snapshot is used.
ANTHROPIC_API_KEY=
