# WellBuilt Home V4 — environment variables
#
# The questionnaire and the Home Snapshot work with NO API key: the results page
# falls back to a transparent, rule-based Snapshot. Set a key only to enable the
# optional AI-personalized Snapshot via /api/generate-snapshot.

# Optional: enables the Claude-powered Snapshot. Without it, the deterministic
# rule-based Snapshot is used.
ANTHROPIC_API_KEY=

# Optional: enables "email me my Snapshot" and the waitlist join form via Resend
# (https://resend.com). Without RESEND_API_KEY, both forms show a clear error
# instead of silently failing.
RESEND_API_KEY=
# Sender address. Defaults to Resend's shared "onboarding@resend.dev" if unset
# (works immediately, no domain setup). Once a sending domain is verified in
# Resend, point this at it, e.g. "WellBuilt Spaces <hello@wellbuilt-spaces.com>".
RESEND_FROM_EMAIL=
# Required for the waitlist form: the address that receives a notification
# email for every signup (this inbox is the waitlist record).
RESEND_NOTIFY_EMAIL=
